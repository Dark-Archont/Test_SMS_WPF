<Window x:Class="Test_SMS_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Тестовое WPF-приложение для SmartMealService"
        Width="920"
        Height="560"
        MinWidth="640"
        MinHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBrush" Color="#3D4F5F"/>
        <Style x:Key="ReadOnlyCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>
        <Style x:Key="EditableCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>
        <Style x:Key="ValueEditTextBox" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            BorderBrush="#888888"
            BorderThickness="1"
            Background="White"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.35" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FAFAFA"
                    CornerRadius="12,12,0,0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,0,0,1"
                    Padding="16,10,8,10"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Тестовое WPF-приложение для SmartMealService"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#222222"
                               VerticalAlignment="Center"
                               Margin="0,0,88,0"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource ChromeButton}"
                                Content="&#x2014;"
                                FontWeight="Bold"
                                Click="Minimize_Click"
                                ToolTip="Свернуть"/>
                        <Button Style="{StaticResource ChromeButton}"
                                Content="&#x2715;"
                                Click="Close_Click"
                                ToolTip="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="16,12,16,16"
                    CornerRadius="10"
                    BorderBrush="#777777"
                    BorderThickness="1"
                    Background="White"
                    ClipToBounds="True">
                <DataGrid x:Name="VariablesGrid"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="True"
                          HeadersVisibility="All"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#DDDDDD"
                          BorderThickness="0"
                          Background="White"
                          RowHeaderWidth="28"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          BeginningEdit="VariablesGrid_OnBeginningEdit"
                          CellEditEnding="VariablesGrid_OnCellEditEnding"
                          PreparingCellForEdit="VariablesGrid_OnPreparingCellForEdit">
                    <DataGrid.RowHeaderStyle>
                        <Style TargetType="DataGridRowHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRowHeader">
                                        <Border Background="#F5F5F5"
                                                BorderBrush="#DDDDDD"
                                                BorderThickness="0,0,1,0">
                                            <TextBlock Text="&#x00BB;"
                                                       FontWeight="Bold"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowHeaderStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F0F0"/>
                            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Поле"
                                            Binding="{Binding Field, Mode=OneWay}"
                                            Width="2*"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ReadOnlyCellText}"/>
                        <DataGridTextColumn x:Name="ValueColumn"
                                            Header="Значение"
                                            Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                            Width="3*"
                                            ElementStyle="{StaticResource EditableCellText}"
                                            EditingElementStyle="{StaticResource ValueEditTextBox}"/>
                        <DataGridTextColumn Header="Комментарий"
                                            Binding="{Binding Comment, Mode=OneWay}"
                                            Width="2.5*"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ReadOnlyCellText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</Window>
